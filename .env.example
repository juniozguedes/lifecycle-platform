# Local Airflow Environment Variables
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------
# Database
# -----------------------------------------------------------------
AIRFLOW_DB_PASSWORD=airflow

# -----------------------------------------------------------------
# Airflow Security
# Generate your own keys: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------
AIRFLOW_FERNET_KEY=your-fernet-key-here-32-chars-minimum
AIRFLOW_SECRET_KEY=your-webserver-secret-key-here

# -----------------------------------------------------------------
# Airflow Admin
# -----------------------------------------------------------------
AIRFLOW_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------
# Airflow UID (for volume permissions)
# Run: echo "AIRFLOW_UID=$(id -u)" >> .env
# -----------------------------------------------------------------
AIRFLOW_UID=50000