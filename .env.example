# Local Airflow Environment Variables
# Copy to .env and fill in your values

# Database
DB_NAME=airflow_db
DB_USER=airflow_user
DB_PASS=__DB_PASSWORD__

# Airflow Security - Generate: python -c "import secrets; print(secrets.token_hex(32))"
FERNET_KEY=__FERNET_KEY__
SECRET_KEY=__SECRET_KEY__

# Admin
ADMIN_USER=admin
ADMIN_PASS=__ADMIN_PASSWORD__

# Project
PROJECT_ID=local-project
BIGQUERY_ENDPOINT=http://host.docker.internal:9060
AIRFLOW_UID=50000